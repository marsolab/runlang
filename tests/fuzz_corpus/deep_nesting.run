package main

use "fmt"

pub fun main() {
    let x = 10
    if x > 0 {
        if x > 5 {
            if x > 8 {
                fmt.println("deep")
            } else {
                fmt.println("mid")
            }
        } else {
            fmt.println("low")
        }
    } else {
        fmt.println("negative")
    }

    var i = 0
    for i < 3 {
        var j = 0
        for j < 2 {
            fmt.print_int(i)
            j = j + 1
        }
        i = i + 1
    }
}
