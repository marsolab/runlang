package main

use "fmt"

pub fun main() {
    let zero = 0
    let neg = 0 - 1
    let big = 999999999

    fmt.print_int(zero)
    fmt.print_int(neg)
    fmt.print_int(big)

    let empty = ""
    fmt.println(empty)
    fmt.println("hello \"world\"")

    if 1 == 1 {
        fmt.println("eq")
    }
    if 1 != 2 {
        fmt.println("neq")
    }
    if 1 < 2 {
        fmt.println("lt")
    }
    if 2 > 1 {
        fmt.println("gt")
    }
    if 1 <= 1 {
        fmt.println("le")
    }
    if 2 >= 2 {
        fmt.println("ge")
    }
}
