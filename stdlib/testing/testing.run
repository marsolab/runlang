package testing

// Operator represents a test comparison operator used with the `expect` keyword.
// Operators are created via methods on T (t.eq, t.gt, t.contains, etc.)
// and describe how to compare a value against an expectation.
pub Operator struct {
    kind    OperatorKind
    want    any = null
    extra   any = null
    inner   []Operator = []Operator{}
}

// OperatorKind enumerates the built-in comparison operators.
pub type OperatorKind = .eq | .ne | .gt | .gte | .lt | .lte | .between
    | .isTrue | .isFalse | .isNil | .notNil | .isErr | .isOk
    | .hasPrefix | .hasSuffix | .contains | .matches
    | .hasLen | .hasCap | .isEmpty | .notEmpty
    | .containsAll | .containsAny
    | .all | .any | .none | .not
    | .approx | .typeOf

// --- Test Context ---

// T is the test context passed explicitly to test blocks via (t).
// Provides logging, failure control, subtests, and operator methods.
pub T struct {
    name      string
    failed    bool
    skipped   bool
    logBuf    []string
    parent    &T?
    isParallel bool
    deadlineMs int
    tempDirVal string?
}

// log records a message in the test log.
// Messages are only printed on failure or when running with -v.
pub fun (t &T) log(msg string) {
}

// logf records a formatted message in the test log.
pub fun (t &T) logf(format string, args ...any) {
}

// fail marks the test as failed but continues execution.
pub fun (t &T) fail() {
}

// failNow marks the test as failed and stops execution immediately.
pub fun (t &T) failNow() {
}

// error logs a message and marks the test as failed.
pub fun (t &T) error(msg string) {
}

// errorf logs a formatted message and marks the test as failed.
pub fun (t &T) errorf(format string, args ...any) {
}

// fatal logs a message, marks the test as failed, and stops immediately.
pub fun (t &T) fatal(msg string) {
}

// fatalf logs a formatted message, marks the test as failed, and stops immediately.
pub fun (t &T) fatalf(format string, args ...any) {
}

// skip marks the test as skipped and stops execution.
pub fun (t &T) skip(reason string) {
}

// run launches a subtest with the given name and body.
// Subtests run as independent test units with their own T context.
pub fun (t &T) run(name string, body fun(t &T)) {
}

// expect asserts that got matches the given operator.
// On failure, reports source location, got vs want, and operator description.
pub fun (t &T) expect(got any, op Operator) {
}

// parallel marks this test as safe to run in parallel with other
// parallel-marked tests. Must be called before any test logic.
pub fun (t &T) parallel() {
}

// name returns the fully-qualified name of the current test/subtest.
pub fun (t @T) name() string {
    return t.name
}

// deadline returns the test timeout deadline as a unix timestamp in nanoseconds.
// Returns 0 if no deadline is set.
pub fun (t @T) deadline() int {
    return t.deadlineMs
}

// tempDir returns a temporary directory that is automatically cleaned up
// after the test completes. Each call returns the same directory.
pub fun (t &T) tempDir() string {
    return ""
}

// failed returns whether the test has been marked as failed.
pub fun (t @T) failed() bool {
    return t.failed
}

// skipped returns whether the test has been marked as skipped.
pub fun (t @T) skipped() bool {
    return t.skipped
}

// --- Operators ---
// Methods on T that return Operator values for use with the `expect` keyword.
// Usage: expect(got, t.eq(want))

// eq returns an operator that asserts deep equality (==).
pub fun (t @T) eq(want any) Operator {
    return Operator{ kind: .eq, want: want }
}

// ne returns an operator that asserts inequality (!=).
pub fun (t @T) ne(want any) Operator {
    return Operator{ kind: .ne, want: want }
}

// gt returns an operator that asserts got > bound.
pub fun (t @T) gt(bound any) Operator {
    return Operator{ kind: .gt, want: bound }
}

// gte returns an operator that asserts got >= bound.
pub fun (t @T) gte(bound any) Operator {
    return Operator{ kind: .gte, want: bound }
}

// lt returns an operator that asserts got < bound.
pub fun (t @T) lt(bound any) Operator {
    return Operator{ kind: .lt, want: bound }
}

// lte returns an operator that asserts got <= bound.
pub fun (t @T) lte(bound any) Operator {
    return Operator{ kind: .lte, want: bound }
}

// between returns an operator that asserts lo <= got <= hi.
pub fun (t @T) between(lo any, hi any) Operator {
    return Operator{ kind: .between, want: lo, extra: hi }
}

// isTrue returns an operator that asserts got is true.
pub fun (t @T) isTrue() Operator {
    return Operator{ kind: .isTrue }
}

// isFalse returns an operator that asserts got is false.
pub fun (t @T) isFalse() Operator {
    return Operator{ kind: .isFalse }
}

// isNil returns an operator that asserts got is null.
pub fun (t @T) isNil() Operator {
    return Operator{ kind: .isNil }
}

// notNil returns an operator that asserts got is not null.
pub fun (t @T) notNil() Operator {
    return Operator{ kind: .notNil }
}

// isErr returns an operator that asserts an error union holds an error.
pub fun (t @T) isErr() Operator {
    return Operator{ kind: .isErr }
}

// isOk returns an operator that asserts an error union holds a success value.
pub fun (t @T) isOk() Operator {
    return Operator{ kind: .isOk }
}

// hasPrefix returns an operator that asserts the string starts with prefix.
pub fun (t @T) hasPrefix(prefix string) Operator {
    return Operator{ kind: .hasPrefix, want: prefix }
}

// hasSuffix returns an operator that asserts the string ends with suffix.
pub fun (t @T) hasSuffix(suffix string) Operator {
    return Operator{ kind: .hasSuffix, want: suffix }
}

// contains returns an operator that asserts substring or element containment.
pub fun (t @T) contains(needle any) Operator {
    return Operator{ kind: .contains, want: needle }
}

// matches returns an operator that asserts a regex match.
pub fun (t @T) matches(pattern string) Operator {
    return Operator{ kind: .matches, want: pattern }
}

// hasLen returns an operator that asserts length equals n.
pub fun (t @T) hasLen(n int) Operator {
    return Operator{ kind: .hasLen, want: n }
}

// hasCap returns an operator that asserts capacity equals n.
pub fun (t @T) hasCap(n int) Operator {
    return Operator{ kind: .hasCap, want: n }
}

// isEmpty returns an operator that asserts length is 0.
pub fun (t @T) isEmpty() Operator {
    return Operator{ kind: .isEmpty }
}

// notEmpty returns an operator that asserts length is > 0.
pub fun (t @T) notEmpty() Operator {
    return Operator{ kind: .notEmpty }
}

// containsAll returns an operator that asserts all items are present.
pub fun (t @T) containsAll(items ...any) Operator {
    return Operator{ kind: .containsAll, want: items }
}

// containsAny returns an operator that asserts at least one item is present.
pub fun (t @T) containsAny(items ...any) Operator {
    return Operator{ kind: .containsAny, want: items }
}

// all returns an operator that asserts all inner operators match (AND).
pub fun (t @T) all(ops ...Operator) Operator {
    return Operator{ kind: .all, inner: ops }
}

// any returns an operator that asserts at least one inner operator matches (OR).
pub fun (t @T) any(ops ...Operator) Operator {
    return Operator{ kind: .any, inner: ops }
}

// none returns an operator that asserts no inner operator matches (NOR).
pub fun (t @T) none(ops ...Operator) Operator {
    return Operator{ kind: .none, inner: ops }
}

// not returns an operator that negates another operator.
pub fun (t @T) not(op Operator) Operator {
    return Operator{ kind: .not, inner: []Operator{op} }
}

// approx returns an operator that asserts numeric approximate equality.
pub fun (t @T) approx(want f64, tolerance f64) Operator {
    return Operator{ kind: .approx, want: want, extra: tolerance }
}

// typeOf returns an operator that asserts the value's type.
pub fun (t @T) typeOf(typeName string) Operator {
    return Operator{ kind: .typeOf, want: typeName }
}

// --- Benchmark Context ---

// B is the benchmark context passed explicitly to bench blocks via (b).
pub B struct {
    name     string
    n        int
    duration int
    running  bool
    bytes    int
}

// resetTimer resets the benchmark timer and counters.
// Call this after expensive setup that should not be measured.
pub fun (b &B) resetTimer() {
}

// startTimer starts or resumes timing.
// Called automatically before the benchmark body executes.
pub fun (b &B) startTimer() {
}

// stopTimer pauses timing. Use with startTimer to exclude
// sections from measurement.
pub fun (b &B) stopTimer() {
}

// reportMetric adds a custom metric to the benchmark results.
pub fun (b &B) reportMetric(name string, value f64, unit string) {
}

// bytesPerOp sets the number of bytes processed per benchmark iteration.
// Used to compute throughput (MB/s) in results.
pub fun (b &B) bytesPerOp(n int) {
}

// run launches a sub-benchmark.
pub fun (b &B) run(name string, body fun(b &B)) {
}

// --- Test Results ---

// TestResult holds the summary of a test run.
pub TestResult struct {
    passed   int
    failed   int
    skipped  int
    fuzzed   int
    benched  int
    failures []string
    duration int
}

// total returns the total number of tests run.
pub fun (r @TestResult) total() int {
    return r.passed + r.failed + r.skipped
}

// ok returns true if all tests passed (no failures).
pub fun (r @TestResult) ok() bool {
    return r.failed == 0
}

// --- Fuzz Context ---

// F is the fuzz context, available inside fuzz test blocks for
// adding seed corpus entries programmatically.
pub F struct {
    name     string
    corpus   [][]byte
    fuzzFunc fun(data []byte)
}

// add adds a seed corpus entry. Each argument is one entry.
// The types must match the fuzz function parameters.
pub fun (f &F) add(args ...any) {
}
