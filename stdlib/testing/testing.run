package testing

// T is the test context passed to each test function.
// It provides methods for logging, failing, and skipping tests.
pub T struct {
    name    string
    failed  bool
    skipped bool
    log_buf []string
}

// log records a message in the test log.
pub fun (t &T) log(msg string) {
}

// logf records a formatted message in the test log.
pub fun (t &T) logf(format string, args ...any) {
}

// fail marks the test as failed but continues execution.
pub fun (t &T) fail() {
}

// failNow marks the test as failed and stops execution.
pub fun (t &T) failNow() {
}

// error logs a message and marks the test as failed.
pub fun (t &T) error(msg string) {
}

// errorf logs a formatted message and marks the test as failed.
pub fun (t &T) errorf(format string, args ...any) {
}

// fatal logs a message, marks the test as failed, and stops execution.
pub fun (t &T) fatal(msg string) {
}

// fatalf logs a formatted message, marks the test as failed, and stops execution.
pub fun (t &T) fatalf(format string, args ...any) {
}

// skip marks the test as skipped and stops execution.
pub fun (t &T) skip(msg string) {
}

// expect asserts that a condition is true. If not, the test is marked as failed
// with the given message.
pub fun expect(condition bool, msg string) {
}

// expectEq asserts that expected and actual are equal.
pub fun expectEq(expected any, actual any) {
}

// expectNe asserts that a and b are not equal.
pub fun expectNe(a any, b any) {
}

// expectTrue asserts that the condition is true.
pub fun expectTrue(condition bool) {
}

// expectFalse asserts that the condition is false.
pub fun expectFalse(condition bool) {
}

// expectError asserts that the given error union contains an error.
pub fun expectError(result any) {
}

// fail marks the current test as failed with the given message.
pub fun fail(msg string) {
}

// B is the benchmark context passed to each benchmark function.
// It provides timing control and iteration counting.
pub B struct {
    name     string
    n        int
    duration int
    running  bool
    bytes    int
}

// resetTimer resets the benchmark timer and counters.
// It does not affect whether the timer is running.
pub fun (b &B) resetTimer() {
}

// startTimer starts timing the benchmark. This function is called
// automatically before a benchmark function is invoked.
pub fun (b &B) startTimer() {
}

// stopTimer stops timing the benchmark.
pub fun (b &B) stopTimer() {
}

// reportMetric adds a custom reported metric to the benchmark results.
pub fun (b &B) reportMetric(n f64, unit string) {
}

// setBytes records the number of bytes processed in a single
// benchmark iteration. This is used to compute throughput.
pub fun (b &B) setBytes(n int) {
}

// runN runs the benchmark function f n times.
pub fun (b &B) runN(n int, f fun(b &B)) {
}

// TestResult holds the summary of a test run.
pub TestResult struct {
    passed   int
    failed   int
    skipped  int
    failures []string
}

// total returns the total number of tests run.
pub fun (r @TestResult) total() int {
    return 0
}

// ok returns true if all tests passed.
pub fun (r @TestResult) ok() bool {
    return false
}
