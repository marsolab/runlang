package math

use "testing"

test "snake_case constants are exposed" (t &testing.T) {
    t.assert(max_float == maxFloat)
    t.assert(min_float == minFloat)
}

test "basic helpers" (t &testing.T) {
    t.assert(abs(-3.5) == 3.5)
    t.assert(min(4.0, 5.0) == 4.0)
    t.assert(max(4.0, 5.0) == 5.0)
    t.assert(floor(2.9) == 2.0)
    t.assert(ceil(2.1) == 3.0)
    t.assert(trunc(-2.9) == -2.0)
}

test "special value helpers" (t &testing.T) {
    t.assert(is_nan(nan))
    t.assert(is_inf(inf))
    t.assert(!is_nan(1.0))
    t.assert(!is_inf(1.0))
}
