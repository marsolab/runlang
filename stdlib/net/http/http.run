// serveFile replies to the request with the contents of the named file.
pub fun serveFile(w &ResponseWriter, r @Request, path string) {
}

// errorResponse replies to the request with the given error message and status.
pub fun errorResponse(w &ResponseWriter, message string, status Status) {
}

// maxBytesReader returns a Reader that reads from r but stops with an
// error after n bytes. This is useful for limiting the size of incoming request bodies.
pub fun maxBytesReader(w &ResponseWriter, r io.ReadCloser, n int) io.ReadCloser {
    return r
}
