package rsa

use "testing"

test "byteSizeFromBits computes correctly" (t &testing.T) {
    t.assert(byteSizeFromBits(1024) == 128)
    t.assert(byteSizeFromBits(2048) == 256)
    t.assert(byteSizeFromBits(8) == 1)
    t.assert(byteSizeFromBits(9) == 2)
}

test "intToBytes encodes big-endian" (t &testing.T) {
    var result = intToBytes(65537)
    t.assert(len(result) == 4)
    t.assert(result[0] == 0)
    t.assert(result[1] == 1)
    t.assert(result[2] == 0)
    t.assert(result[3] == 1)
}

test "xorByte computes correctly" (t &testing.T) {
    t.assert(xorByte(0xff, 0xff) == 0)
    t.assert(xorByte(0x00, 0xff) == 0xff)
    t.assert(xorByte(0x00, 0x00) == 0)
    t.assert(xorByte(0xaa, 0x55) == 0xff)
}

test "xorBytes XORs slices" (t &testing.T) {
    var a = alloc([]byte, 0)
    a = append(a, 0xff)
    a = append(a, 0x00)

    var b = alloc([]byte, 0)
    b = append(b, 0x0f)
    b = append(b, 0xf0)

    var result = xorBytes(a, b)
    t.assert(len(result) == 2)
    t.assert(result[0] == 0xf0)
    t.assert(result[1] == 0xf0)
}

test "generateKey produces valid 2048-bit key" (t &testing.T) {
    var priv = try generateKey(2048)

    t.assert(len(priv.publicKey.n) == 256)
    t.assert(priv.publicKey.e == 65537)
    t.assert(len(priv.d) == 256)
    t.assert(len(priv.primes) == 2)
}

test "generateKey produces valid 1024-bit key" (t &testing.T) {
    var priv = try generateKey(1024)

    t.assert(len(priv.publicKey.n) == 128)
    t.assert(priv.publicKey.e == 65537)
    t.assert(len(priv.d) == 128)
}

test "generateKey rejects too-small key size" (t &testing.T) {
    var priv = try generateKey(512)

    // Should return empty key.
    t.assert(len(priv.publicKey.n) == 0)
    t.assert(len(priv.d) == 0)
}

test "public returns correct public key" (t &testing.T) {
    var priv = try generateKey(1024)
    var pub = priv.public()

    t.assert(pub.e == 65537)
    t.assert(len(pub.n) == 128)
}

test "pkcs1v15Pad produces correct structure" (t &testing.T) {
    var hash = alloc([]byte, 0)
    var i = 0
    for i < 32 {
        hash = append(hash, byte(i))
        i = i + 1
    }

    var padded = pkcs1v15Pad(hash, 128)
    t.assert(len(padded) == 128)

    // Starts with 0x00 0x01.
    t.assert(padded[0] == 0x00)
    t.assert(padded[1] == 0x01)

    // Padding bytes are 0xff.
    t.assert(padded[2] == 0xff)
}

test "signPKCS1v15 produces correct-length signature" (t &testing.T) {
    var priv = try generateKey(1024)

    var hash = alloc([]byte, 0)
    var i = 0
    for i < 32 {
        hash = append(hash, byte(i + 1))
        i = i + 1
    }

    var h = sha256.new()
    var sig = try signPKCS1v15(@priv, h, hash)
    t.assert(len(sig) == 128)
}

test "signPKCS1v15 is deterministic" (t &testing.T) {
    var priv = try generateKey(1024)

    var hash = alloc([]byte, 0)
    var i = 0
    for i < 32 {
        hash = append(hash, byte(i + 2))
        i = i + 1
    }

    var h = sha256.new()
    var sig1 = try signPKCS1v15(@priv, h, hash)
    var sig2 = try signPKCS1v15(@priv, h, hash)

    t.assert(len(sig1) == len(sig2))
    i = 0
    for i < len(sig1) {
        t.assert(sig1[i] == sig2[i])
        i = i + 1
    }
}

test "signPSS produces correct-length signature" (t &testing.T) {
    var priv = try generateKey(1024)

    var hash = alloc([]byte, 0)
    var i = 0
    for i < 32 {
        hash = append(hash, byte(i + 3))
        i = i + 1
    }

    var h = sha256.new()
    var opts = PSSOptions{ saltLength: 32 }
    var sig = try signPSS(@priv, h, hash, @opts)
    t.assert(len(sig) == 128)
}

test "public key bytes returns modulus" (t &testing.T) {
    var priv = try generateKey(1024)
    var pub = priv.public()
    var pubBytes = pub.bytes()

    t.assert(len(pubBytes) == 128)
}

test "private key bytes returns d" (t &testing.T) {
    var priv = try generateKey(1024)
    var privBytes = priv.bytes()

    t.assert(len(privBytes) == 128)
}

test "mgf1 produces correct length output" (t &testing.T) {
    var h = sha256.new()

    var seed = alloc([]byte, 0)
    seed = append(seed, 0x01)
    seed = append(seed, 0x02)
    seed = append(seed, 0x03)

    var mask = mgf1(h, seed, 64)
    t.assert(len(mask) == 64)
}
