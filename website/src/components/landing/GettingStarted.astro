---
---

<section class="py-20">
  <div class="mx-auto max-w-3xl px-6">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white">Get started</h2>
      <p class="text-lg text-gray-400">Run's compiler is written in Zig. Build from source in seconds.</p>
    </div>
    <div class="rounded-xl border border-white/10 bg-run-code-bg">
      <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
        <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
        <span class="ml-3 text-xs text-gray-500">terminal</span>
      </div>
      <pre class="p-6 text-sm leading-loose"><code class="text-gray-300"><span class="text-green-400">$</span> git clone https://github.com/marsolab/runlang.git
<span class="text-green-400">$</span> cd runlang
<span class="text-green-400">$</span> zig build
<span class="text-green-400">$</span> zig build run -- run hello.run
<span class="text-gray-500">Hello, World!</span></code></pre>
    </div>
    <p class="mt-6 text-center text-sm text-gray-500">
      Requires <a href="https://ziglang.org/" target="_blank" rel="noopener noreferrer" class="text-run-primary hover:underline">Zig 0.15</a> or later.
    </p>
  </div>
</section>
