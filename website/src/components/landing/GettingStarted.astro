---
---

<style>
  .install-tabs input[type="radio"] {
    display: none;
  }
  .install-tabs .tab-label {
    cursor: pointer;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    color: #9ca3af;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .install-tabs .tab-label:hover {
    color: #d1d5db;
  }
  .install-tabs input[type="radio"]:checked + .tab-label {
    color: #e5e7eb;
    border-bottom-color: var(--run-primary, #8b5cf6);
  }
  .install-tabs .tab-panel {
    display: none;
  }
  .install-tabs #tab-macos:checked ~ .tab-panels .panel-macos,
  .install-tabs #tab-linux:checked ~ .tab-panels .panel-linux,
  .install-tabs #tab-source:checked ~ .tab-panels .panel-source {
    display: block;
  }
</style>

<section class="py-20">
  <div class="mx-auto max-w-3xl px-6">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white">Get started</h2>
      <p class="text-lg text-gray-400">Install Run in seconds on macOS, Linux, or build from source.</p>
    </div>
    <div class="install-tabs rounded-xl border border-white/10 bg-run-code-bg">
      <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
        <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
        <span class="ml-3 flex-1"></span>
        <input type="radio" name="install-tab" id="tab-macos" checked />
        <label for="tab-macos" class="tab-label">macOS</label>
        <input type="radio" name="install-tab" id="tab-linux" />
        <label for="tab-linux" class="tab-label">Linux</label>
        <input type="radio" name="install-tab" id="tab-source" />
        <label for="tab-source" class="tab-label">From Source</label>
      </div>
      <div class="tab-panels">
        <div class="tab-panel panel-macos">
          <pre class="overflow-x-auto p-6 text-sm leading-loose"><code class="text-gray-300"><span class="text-gray-500"># Homebrew</span>
<span class="text-green-400">$</span> brew install marsolab/tap/run

<span class="text-gray-500"># Or via install script</span>
<span class="text-green-400">$</span> curl -fsSL https://runlang.dev/install.sh | sh</code></pre>
        </div>
        <div class="tab-panel panel-linux">
          <pre class="overflow-x-auto p-6 text-sm leading-loose"><code class="text-gray-300"><span class="text-gray-500"># Install script</span>
<span class="text-green-400">$</span> curl -fsSL https://runlang.dev/install.sh | sh

<span class="text-gray-500"># Or via apt (Debian/Ubuntu)</span>
<span class="text-green-400">$</span> sudo dpkg -i run_&lt;version&gt;_amd64.deb</code></pre>
        </div>
        <div class="tab-panel panel-source">
          <pre class="overflow-x-auto p-6 text-sm leading-loose"><code class="text-gray-300"><span class="text-green-400">$</span> git clone https://github.com/marsolab/runlang.git
<span class="text-green-400">$</span> cd runlang
<span class="text-green-400">$</span> zig build
<span class="text-green-400">$</span> zig build run -- run hello.run
<span class="text-gray-500">Hello, World!</span></code></pre>
        </div>
      </div>
    </div>
    <p class="mt-6 text-center text-sm text-gray-500">
      Requires <a href="https://ziglang.org/" target="_blank" rel="noopener noreferrer" class="text-run-primary hover:underline">Zig 0.15</a> or later.
    </p>
  </div>
</section>
